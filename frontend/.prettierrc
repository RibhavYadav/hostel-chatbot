{
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "es5",
	"bracketSameLine": true,
	"printWidth": 100,
	"plugins": [
		"@ianvs/prettier-plugin-sort-imports",
		"prettier-plugin-svelte",
		"prettier-plugin-tailwindcss"
	],
	"importOrder": [
		"<TYPES>",
		"^(svelte|@sveltejs)/(.*)$",
		"<BUILTIN_MODULES>",
		"<THIRD_PARTY_MODULES>",
		"",
		"^\\$app/(.*)$",
		"^\\$env/(.*)$",
		"^\\$service-worker$",
		"",
		"^\\$lib/types/(.*)$",
		"^\\$lib/stores/(.*)$",
		"^\\$lib/services/(.*)$",
		"",
		"^\\$lib/components/(.*)$",
		"^\\$lib/(.*)$",
		"",
		"^[./]"
	],
	"importOrderParserPlugins": ["typescript", "jsx", "decorators-legacy"],
	"importOrderTypeScriptVersion": "5.0.0",
	"overrides": [
		{
			"files": "*.svelte",
			"options": {
				"parser": "svelte"
			}
		}
	],
	"tailwindStylesheet": "./src/routes/layout.css"
}
