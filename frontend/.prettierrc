{
  "useTabs": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSameLine": true,
  "printWidth": 100,
  "plugins": [
    "prettier-plugin-svelte",
    "prettier-plugin-tailwindcss"
  ],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte",
        "bracketSameLine": true,
        "svelteBracketSameLine": true
      }
    }
  ],
  "tailwindStylesheet": "./src/routes/layout.css"
}
